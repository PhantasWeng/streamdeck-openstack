{
	"name": "streamdeck-openstack",
	"version": "0.1.0",
	"description": "Stream Deck plugin to monitor and control OpenStack instances (status / resource usage / power).",
	"author": "Phantas Weng",
	"license": "MIT",
	"scripts": {
		"build": "node scripts/build.mjs",
		"bump": "node scripts/bump.mjs",
		"clean": "rm -rf com.phantas-weng.openstack.sdPlugin/bin",
		"build:bundle": "yarn clean && rollup -c",
		"icons": "node scripts/generate-icons.mjs",
		"verify": "node scripts/verify-openstack.mjs",
		"watch": "yarn clean && rollup -c -w --watch.onEnd=\"open -g 'streamdeck://plugins/restart/com.phantas-weng.openstack'\"",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"type": "module",
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@elgato/cli": "^1.7.4",
		"@rollup/plugin-commonjs": "^28.0.0",
		"@rollup/plugin-json": "^6.1.0",
		"@rollup/plugin-node-resolve": "^15.2.2",
		"@rollup/plugin-terser": "^0.4.4",
		"@rollup/plugin-typescript": "^12.1.0",
		"@tsconfig/node20": "^20.1.2",
		"@types/node": "~20.15.0",
		"rollup": "^4.0.2",
		"tslib": "^2.6.2",
		"typescript": "^5.2.2",
		"vitest": "^3.0.0"
	},
	"dependencies": {
		"@elgato/streamdeck": "^2.1.0",
		"canvas": "^3.2.3"
	}
}
